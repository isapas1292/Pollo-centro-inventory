generator client {
  provider = "prisma-client-js"
  engineType = "library"
}

datasource db {
  provider = "sqlserver"
  url      = env("DATABASE_URL")
}

model Inventario {
  IdProducto         Int                  @id(map: "PK__Inventar__098892101D110A78") @default(autoincrement())
  IdProveedor        Int?
  NombreProducto     String               @db.VarChar(150)
  Descripcion        String?              @db.VarChar(255)
  Categoria          String?              @db.VarChar(100)
  UnidadMedida       String               @db.VarChar(50)
  CantidadDisponible Decimal              @default(0, map: "DF__Inventari__Canti__33D4B598") @db.Decimal(10, 2)
  StockMinimo        Decimal              @default(0, map: "DF__Inventari__Stock__34C8D9D1") @db.Decimal(10, 2)
  CostoUnitario      Decimal              @default(0, map: "DF__Inventari__Costo__35BCFE0A") @db.Decimal(10, 2)
  FechaRegistro      DateTime?            @default(now(), map: "DF__Inventari__Fecha__36B12243") @db.DateTime
  FechaVencimiento   DateTime?            @db.Date
  Estado             Boolean?             @default(true, map: "DF__Inventari__Estad__37A5467C")
  PackMeas           String?              @db.NVarChar(100)
  TotalUnits         Decimal              @default(0, map: "DF_Inventario_TotalUnits") @db.Decimal(18, 2)
  Proveedores        Proveedores?         @relation(fields: [IdProveedor], references: [IdProveedor], onDelete: NoAction, onUpdate: NoAction, map: "FK_Inventario_Proveedores")
  RecetaIngredientes RecetaIngredientes[]
}

model Proveedores {
  IdProveedor     Int          @id(map: "PK__Proveedo__E8B631AF768462ED") @default(autoincrement())
  NombreProveedor String       @db.VarChar(150)
  RNC             String?      @db.VarChar(20)
  Telefono        String?      @db.VarChar(20)
  Correo          String?      @db.VarChar(150)
  Direccion       String?      @db.VarChar(255)
  FechaRegistro   DateTime?    @default(now(), map: "DF__Proveedor__Fecha__300424B4") @db.DateTime
  Estado          Boolean?     @default(true, map: "DF__Proveedor__Estad__30F848ED")
  Inventario      Inventario[]
}

model RecetaIngredientes {
  IdRecetaIngrediente Int        @id(map: "PK__RecetaIn__263C8BB6B7689310") @default(autoincrement())
  IdReceta            Int
  IdProducto          Int
  CantidadNecesaria   Decimal    @db.Decimal(10, 2)
  UnidadMedida        String     @db.VarChar(50)
  Inventario          Inventario @relation(fields: [IdProducto], references: [IdProducto], onUpdate: NoAction, map: "FK_RecetaIngredientes_Inventario")
  Recetas             Recetas    @relation(fields: [IdReceta], references: [IdReceta], onUpdate: NoAction, map: "FK_RecetaIngredientes_Recetas")
}

model Recetas {
  IdReceta                 Int                  @id(map: "PK__Recetas__2CEFF15754938DBD") @default(autoincrement())
  NombreReceta             String               @db.VarChar(150)
  Descripcion              String?              @db.VarChar(255)
  Porciones                Int                  @default(1, map: "DF__Recetas__Porcion__3B75D760")
  TiempoPreparacionMinutos Int?
  PrecioVenta              Decimal?             @db.Decimal(10, 2)
  FechaCreacion            DateTime?            @default(now(), map: "DF__Recetas__FechaCr__3C69FB99") @db.DateTime
  Estado                   Boolean?             @default(true, map: "DF__Recetas__Estado__3D5E1FD2")
  RecetaIngredientes       RecetaIngredientes[]
}

model Roles {
  IdRol         Int        @id(map: "PK__Roles__2A49584CE97B69C8") @default(autoincrement())
  NombreRol     String     @unique(map: "UQ__Roles__4F0B537F75FF226B") @db.VarChar(50)
  Descripcion   String?    @db.VarChar(255)
  FechaCreacion DateTime?  @default(now(), map: "DF__Roles__FechaCrea__25869641") @db.DateTime
  Estado        Boolean?   @default(true, map: "DF__Roles__Estado__267ABA7A")
  Usuarios      Usuarios[]
}

model Usuarios {
  IdUsuario     Int       @id(map: "PK__Usuarios__5B65BF973DDE8820") @default(autoincrement())
  IdRol         Int
  Nombre        String    @db.VarChar(100)
  Apellido      String    @db.VarChar(100)
  Usuario       String    @unique(map: "UQ__Usuarios__E3237CF720E5B6D4") @db.VarChar(50)
  Correo        String    @unique(map: "UQ__Usuarios__60695A19B1E2865D") @db.VarChar(150)
  Contrasena    String    @db.VarChar(255)
  Telefono      String?   @db.VarChar(20)
  FechaCreacion DateTime? @default(now(), map: "DF__Usuarios__FechaC__2B3F6F97") @db.DateTime
  Estado        Boolean?  @default(true, map: "DF__Usuarios__Estado__2C3393D0")
  Roles         Roles     @relation(fields: [IdRol], references: [IdRol], onUpdate: NoAction, map: "FK_Usuarios_Roles")
}
