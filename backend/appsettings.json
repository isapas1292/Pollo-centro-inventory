{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Microsoft.EntityFrameworkCore.Database.Command": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "DefaultConnection": "Server=localhost,1433;Database=PolloCentro;Trusted_Connection=True;TrustServerCertificate=True;"
  },
  "Jwt": {
    "_comment": "El secreto NO se guarda aquí. En desarrollo usa User Secrets (dotnet user-secrets set \"Jwt:Secret\" ...); en producción la variable de entorno Jwt__Secret.",
    "Issuer": "PolloCentro.Api",
    "Audience": "PolloCentro.Client",
    "ExpiryHours": 8
  },
  "Cors": {
    "AllowedOrigins": [ "http://localhost:4200" ]
  },
  "Database": {
    "SeedOnStartup": false
  },
  "ReverseProxy": {
    "KnownProxies": []
  },
  "WhatsApp": {
    "_comment": "Los SECRETOS (AccessToken, PhoneNumberId) NO van aquí. Configúralos por variables de entorno (WhatsApp__AccessToken, WhatsApp__PhoneNumberId) o User Secrets.",
    "Enabled": true,
    "ApiBaseUrl": "https://graph.facebook.com",
    "ApiVersion": "v21.0",
    "AccessToken": "",
    "PhoneNumberId": "",
    "RecipientNumber": "",
    "TemplateName": "",
    "TemplateLanguage": "es"
  }
}
